CONTENT_PORT=8791
CONTENT_DB_PATH=./node/data/content.db
# Leave empty for local dev/public read.
CONTENT_READ_TOKEN=
# Enable editor JWT auth (recommended in production).
CONTENT_JWT_SECRET=
CONTENT_JWT_TTL_SECONDS=43200
CONTENT_DRAFT_LOCK_TTL_SECONDS=600
# Optional first admin seed (auto-created only if editor_users is empty).
CONTENT_EDITOR_SEED_EMAIL=
CONTENT_EDITOR_SEED_PASSWORD=
CONTENT_EDITOR_SEED_NAME=Content Admin
CONTENT_EDITOR_SEED_ROLE=admin

# Optional: release audio generation/verification via realtime Polly endpoint.
CONTENT_TTS_ALIGNED_ENDPOINT=https://realtime.curso-ingles.com/realtime/tts/aligned
CONTENT_TTS_ALIGNED_TOKEN=
CONTENT_TTS_ALIGNED_TIMEOUT_MS=20000
CONTENT_TTS_ALIGNED_CONCURRENCY=3
CONTENT_TTS_ALIGNED_POLLY_ENGINE=neural
CONTENT_TTS_ALIGNED_VOICE_EN_US=Danielle
CONTENT_TTS_ALIGNED_VOICE_EN_GB=Amy
CONTENT_TTS_ALIGNED_VOICE_ES_ES=Lucia
CONTENT_TTS_VERIFY_HEAD_TIMEOUT_MS=4000
