CONTENT_PORT=8791
CONTENT_DB_PATH=./node/data/content.db
# Leave empty for local dev/public read.
CONTENT_READ_TOKEN=
# Enable editor JWT auth (recommended in production).
CONTENT_JWT_SECRET=
CONTENT_JWT_TTL_SECONDS=43200
CONTENT_DRAFT_LOCK_TTL_SECONDS=600
# Optional first admin seed (auto-created only if editor_users is empty).
CONTENT_EDITOR_SEED_EMAIL=
CONTENT_EDITOR_SEED_PASSWORD=
CONTENT_EDITOR_SEED_NAME=Content Admin
CONTENT_EDITOR_SEED_ROLE=admin
