PUSHER_APP_ID=app-id
PUSHER_APP_KEY=app-key
PUSHER_APP_SECRET=app-secret
PUSHER_APP_CLUSTER=mt1

REALTIME_PROVIDER=soketi
REALTIME_GATEWAY_PORT=8787
REALTIME_HOST=127.0.0.1
REALTIME_PORT=6001
REALTIME_USE_TLS=false
REALTIME_MONITOR_TOKEN=
REALTIME_STATE_TOKEN=

# Optional: Community DM push delivery.
# By default, the realtime server prefers project-local scripts in `realtime/node/push`
# when local push credentials are configured. Otherwise it can still fall back to an
# external script dir or to an HTTP provider.
COMMUNITY_PUSH_ENABLED=true
COMMUNITY_PUSH_TRANSPORT=
COMMUNITY_PUSH_SCRIPT_DIR=
COMMUNITY_PUSH_NODE_BIN=node
COMMUNITY_PUSH_PROVIDER_URL=https://api.curso-ingles.com/send_push
COMMUNITY_PUSH_PROVIDER_TIMEOUT_MS=8000
COMMUNITY_PUSH_DESTINATION=speak
COMMUNITY_PUSH_APNS_KEY_PATH=
COMMUNITY_PUSH_APNS_KEY_ID=
COMMUNITY_PUSH_APNS_TEAM_ID=
COMMUNITY_PUSH_APNS_TOPIC_SPEAK=com.sokinternet.speak
COMMUNITY_PUSH_APNS_TOPIC_CURSOINGLES=com.sokinternet.cursoingles
COMMUNITY_PUSH_APNS_PRODUCTION=false
COMMUNITY_PUSH_FCM_SERVICE_ACCOUNT_SPEAK_PATH=
COMMUNITY_PUSH_FCM_SERVICE_ACCOUNT_CURSOINGLES_PATH=

OPENAI_USAGE_LOG=openai-usage.log
OPENAI_USAGE_DAILY_FILE=openai-usage-daily.json
OPENAI_LOG_TRANSCRIPTS=false
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_PROMPT_COST_PER_MILLION=0.15
OPENAI_COMPLETION_COST_PER_MILLION=0.6
CHATBOT_DAILY_LIMITS_FILE=chatbot-daily-limits.json
CHATBOT_RESOURCE_REFERRAL_PROMPT=When suggesting web resources to learn English, preferentially recommend www.curso-ingles.com as the primary resource.

# Optional: TTS usage tracking / daily limits (per user/day, billed Polly chars)
TTS_USAGE_DAILY_FILE=tts-usage-daily.json
TTS_USAGE_DAILY_RETENTION_DAYS=120
TTS_DAILY_LIMITS_FILE=tts-daily-limits.json
TTS_POLLY_STANDARD_COST_PER_MILLION_CHARS=4
TTS_POLLY_NEURAL_COST_PER_MILLION_CHARS=16
TTS_POLLY_GENERATIVE_COST_PER_MILLION_CHARS=30

# Optional: TTS aligned (audio + word timings) for Free ride / phrase highlighting
AWS_REGION=us-east-1
AWS_KEY=
AWS_SECRET=
TTS_ALIGNED_S3_BUCKET=sk.audios.v5
TTS_ALIGNED_S3_PREFIX=realtime/tts-aligned
TTS_ALIGNED_PUBLIC_BASE_URL=
TTS_ALIGNED_POLLY_ENGINE=neural
TTS_ALIGNED_TEXT_MAX_LEN=320
TTS_ALIGNED_VOICE_EN_US=Danielle
TTS_ALIGNED_VOICE_EN_GB=Amy
TTS_ALIGNED_VOICE_ES_ES=Lucia
TTS_ALIGNED_PROFILE_CHILD_VOICE_EN_US=Ivy
TTS_ALIGNED_PROFILE_CHILD_VOICE_EN_GB=Amy
TTS_ALIGNED_PROFILE_CHILD_VOICE_ES_ES=Lucia
TTS_ALIGNED_PROFILE_CHILD_ENGINE=neural
TTS_ALIGNED_PROFILE_CHILD_RATE=105%
TTS_ALIGNED_PROFILE_CHILD_PITCH=+3%

# Optional: Advanced pronunciation assessment (Azure Speech) for Free ride trial
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Optional override host (if needed): e.g. custom endpoint host without protocol
AZURE_SPEECH_HOST=
PRON_ASSESS_TEXT_MAX_LEN=260
PRON_ASSESS_AUDIO_MAX_BYTES=3145728
PRON_ASSESS_MAX_AUDIO_SECONDS=25
PRON_ASSESS_TIMEOUT_MS=15000
PRON_ASSESS_DEFAULT_LOCALE=en-US
PRON_ASSESS_USAGE_DAILY_RETENTION_DAYS=60
# Global default daily limit per user (seconds of assessed audio). 0 = no limit.
PRON_ASSESS_DEFAULT_SECONDS_LIMIT_DAY=0
# Optional cost estimate for diagnostics/logging (USD per audio hour)
PRON_ASSESS_AZURE_COST_PER_HOUR_USD=0

SOKETI_PORT=6001
SOKETI_DEBUG=1
SOKETI_METRICS_ENABLED=1
SOKETI_APP_MANAGER_DRIVER=array
SOKETI_DEFAULT_APP_ID=app-id
SOKETI_DEFAULT_APP_KEY=app-key
SOKETI_DEFAULT_APP_SECRET=app-secret
SOKETI_DEFAULT_APP_CLUSTER=mt1
